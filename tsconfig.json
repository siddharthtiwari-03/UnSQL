{
    "compilerOptions": {
        "target": "ES2020",
        "module": "NodeNext",
        "moduleResolution": "NodeNext",
        "allowJs": true,
        "checkJs": true,
        "declaration": true,
        "emitDeclarationOnly": true,
        "outDir": "types",
        "strict": true,
        "noImplicitAny": true,
        "types": [
            "node"
        ],
        "skipLibCheck": true
    },
    "include": [
        "./*.js",
        "./defs/*.js",
        "types/**/*.d.ts"
    ],
    "exclude": [
        "node_modules",
        "types",
        "eslint.config.js"
    ]
}